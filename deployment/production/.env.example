# 校园互助平台 - 生产环境配置模板
# 请复制此文件为 .env 并修改配置

# ==================== MySQL 配置 ====================
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=campus
MYSQL_USER=campus
MYSQL_PASSWORD=your_secure_db_password_here

# ==================== 应用配置 ====================
# JWT密钥（必须修改为强随机字符串）
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_at_least_64_characters

# JWT过期时间（毫秒，默认7天）
JWT_EXPIRATION=604800000

# 管理后台密码
ADMIN_PASSWORD=your_secure_admin_password_here

# ==================== 时区配置 ====================
TZ=Asia/Shanghai

# ==================== 文件上传配置 ====================
UPLOAD_PATH=./data/uploads

# ==================== 服务器配置 ====================
# 服务器IP（用于生产环境访问）
SERVER_IP=localhost

# ==================== 端口配置 ====================
BACKEND_PORT=8080
ADMIN_PORT=80
NGINX_PORT=80
MYSQL_PORT=3306

# ==================== 健康检查 ====================
HEALTH_CHECK_INTERVAL=30
