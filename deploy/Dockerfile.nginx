# Nginx Dockerfile
# 构建: docker build -f deploy/Dockerfile.nginx -t campus-nginx:latest .

FROM nginx:alpine

# 复制 Nginx 配置
COPY deploy/nginx.conf /etc/nginx/nginx.conf

# 创建上传目录
RUN mkdir -p /var/www/uploads && \
    chown -R nginx:nginx /var/www/uploads

# 暴露端口
EXPOSE 80 443

# 启动 Nginx
CMD ["nginx", "-g", "daemon off;"]
