<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.modules.forum.mapper.PostMapper">

    <!-- 解决 LONGTEXT 字段读取问题 -->
    <resultMap id="BaseResultMap" type="com.campus.modules.forum.entity.Post">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="board_id" property="boardId"/>
        <result column="title" property="title"/>
        <result column="content" property="content" jdbcType="LONGVARCHAR" javaType="java.lang.String"/>
        <result column="images" property="images" jdbcType="LONGVARCHAR" javaType="java.lang.String"/>
        <result column="view_count" property="viewCount"/>
        <result column="like_count" property="likeCount"/>
        <result column="comment_count" property="commentCount"/>
        <result column="collect_count" property="collectCount"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- Comment 结果映射 -->
    <resultMap id="CommentResultMap" type="com.campus.modules.forum.entity.Comment">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="post_id" property="postId"/>
        <result column="parent_id" property="parentId"/>
        <result column="content" property="content" jdbcType="LONGVARCHAR" javaType="java.lang.String"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

</mapper>
